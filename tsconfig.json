{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./packages/core/src/*"],
      "@/ui/*": ["./packages/core/src/ui/*"],
      "@/lib/*": ["./packages/core/src/lib/*"],
      "file-next": ["./packages/core/src/index.ts"],
      "file-next/server": ["./packages/core/src/server/index.ts"],
      "file-next/sync": ["./packages/core/src/sync/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".next", "packages/headless", "packages/cli", "registry", "tests/registry"]
}
